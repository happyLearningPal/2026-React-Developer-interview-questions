2. import React, { useState } from "react";

function App2() {
const [messages, setMessages] = useState([
{ id: 1, text: "Hello!" },
{ id: 2, text: "Welcome to chat." },
]);

    const addMessage = () => {
    	setMessages([...messages, { id: Date.now(), text: "New message" }]);
    };

    return (
    	<div>
    		<button onClick={addMessage}>Add Message</button>
    		<ul>
    			{messages.map((msg) => (
    				<li key={msg.id}>{msg.text}</li> // ❌ All re-render on new message
    			))}
    		</ul>
    	</div>
    );

}

export default ChatApp;

